{
  "info": {
    "_postman_id": "dc-api-collection-001",
    "name": "DigitalCoach API",
    "description": "API collection for the DigitalCoach interview coaching platform. This FastAPI backend provides video analysis, audio sentiment analysis, STAR method feedback, and HeyGen AI avatar integration.\n\n## Base URL\nSet the `{{baseUrl}}` variable in your environment (e.g., `http://localhost:8000`).\n\n## Job-Based Architecture\nMost analysis endpoints follow an async job pattern:\n1. POST to start a job → returns `job_id`\n2. GET with `job_id` to poll status until `completed` or `failed`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "Health & Status",
      "description": "Basic health check and status endpoints",
      "item": [
        {
          "name": "Root - Welcome",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "    pm.response.to.be.success;",
                  "});",
                  "",
                  "pm.test('Response is valid JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Root endpoint returning a welcome message. Use this to verify the API is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jobs",
      "description": "Generic job status polling endpoints",
      "item": [
        {
          "name": "Get Job Results",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "    pm.response.to.be.success;",
                  "});",
                  "",
                  "pm.test('Response is valid JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('Response contains job_id and status', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('job_id');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "});",
                  "",
                  "pm.test('Status is a valid job status', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const validStatuses = ['pending', 'processing', 'completed', 'failed'];",
                  "    pm.expect(validStatuses).to.include(jsonData.status);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/results/:job_id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs", "results", ":job_id"],
              "variable": [
                {
                  "key": "job_id",
                  "value": "",
                  "description": "The unique job identifier returned when starting a job"
                }
              ]
            },
            "description": "Poll the status and results of any job by its ID. Returns job status (pending, processing, completed, failed) and results when complete."
          },
          "response": []
        }
      ]
    },
